<?xml version='1.0' encoding='utf-8'?>
<PARAMDEF XmlVersion="0">
    <ParamType>DEMO_POINT_LIGHT_PARAM</ParamType>
    <DataVersion>1</DataVersion>
    <BigEndian>true</BigEndian>
    <Unicode>true</Unicode>
    <FormatVersion>104</FormatVersion>
    <Fields>
        <Field Def="f32 offsetX">
            <DisplayName>Position</DisplayName>
            <Description>x座標の位置のオフセットを設定します。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Minimum>-999</Minimum>
            <Maximum>999</Maximum>
            <Increment>1</Increment>
            <SortID>0</SortID>
        </Field>
        <Field Def="f32 offsetY">
            <DisplayName>Position Y</DisplayName>
            <Description>y座標の位置のオフセットを設定します。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Minimum>-999</Minimum>
            <Maximum>999</Maximum>
            <Increment>1</Increment>
            <SortID>1</SortID>
        </Field>
        <Field Def="f32 offsetZ">
            <DisplayName>Position Z</DisplayName>
            <Description>y座標の位置のオフセットを設定します。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Minimum>-999</Minimum>
            <Maximum>999</Maximum>
            <Increment>1</Increment>
            <SortID>2</SortID>
        </Field>
        <Field Def="u8 diffuseR">
            <DisplayName>Diffuse R</DisplayName>
            <Description>デフューズの赤色を設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>3</SortID>
        </Field>
        <Field Def="u8 diffuseG">
            <DisplayName>Diffuse G</DisplayName>
            <Description>デフューズの緑色を設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>4</SortID>
        </Field>
        <Field Def="u8 diffuseB">
            <DisplayName>Diffuse B</DisplayName>
            <Description>デフューズの青色を設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>5</SortID>
        </Field>
        <Field Def="u8 diffuseA">
            <DisplayName>Diffuse A</DisplayName>
            <Description>デフューズのαを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>6</SortID>
        </Field>
        <Field Def="u8 specularR">
            <DisplayName>Specular R</DisplayName>
            <Description>スペキュラの赤色を設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>7</SortID>
        </Field>
        <Field Def="u8 specularG">
            <DisplayName>Specular G</DisplayName>
            <Description>スペキュラの緑色を設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>8</SortID>
        </Field>
        <Field Def="u8 specularB">
            <DisplayName>Specular B</DisplayName>
            <Description>スペキュラの青色を設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>9</SortID>
        </Field>
        <Field Def="u8 specularA">
            <DisplayName>Specular A</DisplayName>
            <Description>スペキュラのαを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>10</SortID>
        </Field>
        <Field Def="f32 radius">
            <DisplayName>Light radius</DisplayName>
            <Description>ライトの半径を設定します。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>999</Maximum>
            <Increment>1</Increment>
            <SortID>11</SortID>
        </Field>
        <Field Def="f32 priority">
            <DisplayName>Priority</DisplayName>
            <Description>表示しようとする光源の優先度(0.0～1.0)です。表示できる光源の最大数を超えた場合には優先度が高いものほど表示されやすくなります。ただし、状況に応じて順序が前後する可能性もあります。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>12</SortID>
        </Field>
        <Field Def="f32 depthShadow">
            <DisplayName>Darkness of shadow</DisplayName>
            <Description>影の濃さ(0.0～1.0)です。高いほど濃く表示され、0.0で影無効と同等の処理となります。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>14</SortID>
        </Field>
        <Field Def="u16 blinkTimeMax">
            <DisplayName>Blinking time (maximum)</DisplayName>
            <Description>明滅の最小時間を設定します。最小～最大の範囲からランダムで抽出された値が1回の明滅時間となり、明滅毎に繰り返します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>99</Maximum>
            <Increment>1</Increment>
            <SortID>15</SortID>
        </Field>
        <Field Def="u16 blinkTimeMin">
            <DisplayName>Blinking time (min)</DisplayName>
            <Description>明滅の最大時間を設定します。最小～最大の範囲からランダムで抽出された値が1回の明滅時間となり、明滅毎に繰り返します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>99</Maximum>
            <Increment>1</Increment>
            <SortID>16</SortID>
        </Field>
        <Field Def="f32 blinkPower">
            <DisplayName>Strength of flickering</DisplayName>
            <Description>明滅の最小強さを設定します。最小～1.0の範囲での強さで明滅が行われます。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>17</SortID>
        </Field>
        <Field Def="u8 enableShadow">
            <DisplayName>Cast a shadow</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>影を落とすかを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>1</Increment>
            <SortID>13</SortID>
        </Field>
        <Field Def="dummy8 dummy[3]">
            <DisplayName>Dummy</DisplayName>
            <SortID>18</SortID>
        </Field>
    </Fields>
</PARAMDEF>