<?xml version='1.0' encoding='utf-8'?>
<PARAMDEF XmlVersion="0">
    <ParamType>PLAYER_ACTION_PARAM</ParamType>
    <DataVersion>1</DataVersion>
    <BigEndian>true</BigEndian>
    <Unicode>true</Unicode>
    <FormatVersion>104</FormatVersion>
    <Fields>
        <Field Def="f32 fMaxAdrenaline = 10,000">
            <DisplayName>Maximum total amount of adrenaline [ng]</DisplayName>
            <Description>保持可能なアドレナリンの最大量[ナノグラム]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>1</SortID>
        </Field>
        <Field Def="f32 fDecreaseAderanalinePerSec = 100">
            <DisplayName>Adrenaline reduction amount [ng/s]</DisplayName>
            <Description>1秒当たりのアドレナリン減少量[ナノグラム/秒]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>2</SortID>
        </Field>
        <Field Def="f32 fAdrenalineCoolTime = 10">
            <DisplayName>Adrenaline cool time [sec]</DisplayName>
            <Description>アドレナリンによる加速処理終了時間[秒]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10</Maximum>
            <Increment>0.1</Increment>
            <SortID>3</SortID>
        </Field>
        <Field Def="f32 fMaxDistressAmount = 10,000">
            <DisplayName>Total lactic acid [ng]</DisplayName>
            <Description>保持可能な乳酸の最大量[ナノグラム]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>4</SortID>
        </Field>
        <Field Def="f32 fMinEffectiveDistress">
            <DisplayName>Lactic acid effect lowest value [ng]</DisplayName>
            <Description>乳酸が攻撃などに影響を及ぼし始める最低量[ナノグラム]
(乳酸がこの値未満なら乳酸の影響を受けない)</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>5</SortID>
        </Field>
        <Field Def="f32 fMaxEffectiveDistress = 10,000">
            <DisplayName>Lactic acid effect maximum value [ng]</DisplayName>
            <Description>乳酸が与える影響が最大に達する量[ナノグラム]
(乳酸がこの値以上なら乳酸の影響度合いは100%となる)</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>6</SortID>
        </Field>
        <Field Def="f32 fMinBreathlessAnimWait">
            <DisplayName>Shortness of breath Minimum blend rate</DisplayName>
            <Description>乳酸の影響を受けている際に加算再生する息切れアニメの最低ブレンド率</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>1</Maximum>
            <Increment>0.050000001</Increment>
            <SortID>7</SortID>
        </Field>
        <Field Def="f32 fMaxBreathlessAnimWait = 1">
            <DisplayName>Shortness of breath maximum blend rate</DisplayName>
            <Description>乳酸の影響を受けている際に加算再生する息切れアニメの最大ブレンド率</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>1</Maximum>
            <Increment>0.050000001</Increment>
            <SortID>8</SortID>
        </Field>
        <Field Def="f32 fDecreaseDistressPerSec = 100">
            <DisplayName>Lactic acid reduction amount [ng/s]</DisplayName>
            <Description>1秒当たりの乳酸減少量[ナノグラム/秒]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>9</SortID>
        </Field>
        <Field Def="f32 fMinPivotAngleForGainDistress = 30">
            <DisplayName>Lactic acid addition angle [deg]</DisplayName>
            <Description>旋回攻撃時に乳酸増加倍率が適用される最低角度[度]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>180</Maximum>
            <Increment>0.5</Increment>
            <SortID>10</SortID>
        </Field>
        <Field Def="f32 fDecreaseDistressOnGuard = 5,000">
            <DisplayName>Lactic acid defense reduction value [ng]</DisplayName>
            <Description>防御「成功時」に乳酸が減少する量[ナノグラム]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>11</SortID>
        </Field>
    </Fields>
</PARAMDEF>