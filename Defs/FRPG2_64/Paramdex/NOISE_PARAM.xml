<?xml version='1.0' encoding='utf-8'?>
<PARAMDEF XmlVersion="0">
    <ParamType>NOISE_PARAM</ParamType>
    <DataVersion>1</DataVersion>
    <BigEndian>true</BigEndian>
    <Unicode>true</Unicode>
    <FormatVersion>104</FormatVersion>
    <Fields>
        <Field Def="f32 strengthX = 0.5">
            <DisplayName>Strength in X direction</DisplayName>
            <Description>Ｘ方向の強さ</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>1</SortID>
        </Field>
        <Field Def="f32 strengthY = 0.5">
            <DisplayName>Strength in Y direction</DisplayName>
            <Description>Ｙ方向の強さ</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>2</SortID>
        </Field>
        <Field Def="f32 strengthZ = 0.5">
            <DisplayName>Strength in Z direction</DisplayName>
            <Description>Ｚ方向の強さ</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>3</SortID>
        </Field>
        <Field Def="f32 frequency = 1">
            <DisplayName>period</DisplayName>
            <Description>周期</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>60</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>4</SortID>
        </Field>
        <Field Def="f32 startScale = 1">
            <DisplayName>Scale initial noise to maximum</DisplayName>
            <Description>初期ノイズを最大スケール</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>5</SortID>
        </Field>
        <Field Def="f32 middleScale = 1">
            <DisplayName>midpoint scale</DisplayName>
            <Description>B-Spline中間点スケール</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>6</SortID>
        </Field>
        <Field Def="f32 lastScale = 1">
            <DisplayName>Scale endpoint noise to maximum</DisplayName>
            <Description>終点ノイズを最大スケール</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>7</SortID>
        </Field>
        <Field Def="u32 octavesNum = 3">
            <DisplayName>Number of fractal layers</DisplayName>
            <Description>フラクタルの階層数。この数が増えるほど処理は重くなります。デフォルト3</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Minimum>1</Minimum>
            <Maximum>10</Maximum>
            <Increment>1</Increment>
            <SortID>8</SortID>
        </Field>
        <Field Def="f32 lacunarity = 2">
            <DisplayName>Frequency coefficient for each octave (porosity)</DisplayName>
            <Description>オクターブごとにかかる周波数の係数(空隙性)。デフォルト2.0</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>10</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>9</SortID>
        </Field>
        <Field Def="f32 gain = 0.5">
            <DisplayName>Amplitude coefficient for each octave</DisplayName>
            <Description>オクターブごとにかかる振幅の係数。デフォルト0.5</Description>
            <DisplayFormat>%f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.0099999998</Increment>
            <SortID>10</SortID>
        </Field>
    </Fields>
</PARAMDEF>